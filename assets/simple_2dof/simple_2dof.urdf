<?xml version="1.0"?>
<robot name="simple_2dof">

  <material name="base_color">
    <color rgba="0.30 0.35 0.45 1.0"/>
  </material>
  <material name="arm_color">
    <color rgba="0.80 0.50 0.20 1.0"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.20 0.20 0.10"/></geometry>
      <material name="base_color"/>
    </visual>
  </link>

  <link name="upper_arm">
    <visual>
      <origin xyz="0 0 0.25"/>
      <geometry><box size="0.08 0.08 0.50"/></geometry>
      <material name="arm_color"/>
    </visual>
  </link>

  <link name="forearm">
    <visual>
      <origin xyz="0 0 0.20"/>
      <geometry><box size="0.06 0.06 0.40"/></geometry>
      <material name="arm_color"/>
    </visual>
  </link>

  <joint name="shoulder" type="revolute">
    <parent link="base_link"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.10"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="5"/>
  </joint>

  <joint name="elbow" type="revolute">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0 0 0.50"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="5"/>
  </joint>

</robot>
